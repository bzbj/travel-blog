---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="我的旅行博客" description="记录旅途中的美好时光">
  <header class="hero">
    <nav class="nav">
      <a href="/" class="nav-brand">🌍 旅行日记</a>
      <div class="nav-links">
        <a href="/">首页</a>
        <a href="/posts">文章</a>
        <a href="/about">关于</a>
      </div>
    </nav>

    <div class="hero-content">
      <h1 class="hero-title">用脚步丈量世界<br/>用文字记录时光</h1>
      <p class="hero-subtitle">分享我的旅行故事、美食探索和旅途中的点点滴滴</p>
    </div>
  </header>

  <main class="main">
    <section class="recent-posts">
      <h2 class="section-title">最新游记</h2>
      <div class="post-grid">
        {posts.map(post => (
          <article class="post-card">
            <a href={`/posts/${post.slug}`} class="post-card-link">
              <div class="post-card-content">
                <h3 class="post-card-title">{post.data.title}</h3>
                <p class="post-card-description">{post.data.description}</p>
                <div class="post-card-meta">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  {post.data.location && (
                    <span class="post-card-location">📍 {post.data.location}</span>
                  )}
                </div>
                {post.data.tags && (
                  <div class="post-card-tags">
                    {post.data.tags.slice(0, 3).map(tag => (
                      <span class="post-card-tag">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <p>© 2026 我的旅行博客 · 用 ❤️ 记录旅途</p>
  </footer>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    min-height: 60vh;
    padding-bottom: 4rem;
  }

  .nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-brand {
    font-size: 1.5rem;
    font-weight: 600;
    color: white;
    text-decoration: none;
  }

  .nav-brand:hover {
    color: var(--color-accent-light);
    text-decoration: none;
  }

  .nav-links a {
    margin-left: 2rem;
    color: rgba(255,255,255,0.9);
    font-size: 1rem;
    font-weight: 500;
  }

  .nav-links a:hover {
    color: white;
    text-decoration: none;
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 1.5rem 2rem;
    text-align: center;
  }

  .hero-title {
    font-size: 3rem;
    font-family: var(--font-serif);
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: rgba(255,255,255,0.9);
    max-width: 600px;
    margin: 0 auto;
  }

  .main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .section-title {
    font-size: 2rem;
    text-align: center;
    margin-bottom: 2.5rem;
    color: var(--color-text);
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
  }

  .post-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: transform 0.2s, box-shadow 0.2s;
    overflow: hidden;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }

  .post-card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .post-card-link:hover {
    text-decoration: none;
  }

  .post-card-content {
    padding: 1.75rem;
  }

  .post-card-title {
    font-size: 1.375rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
    font-family: var(--font-serif);
  }

  .post-card-description {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }

  .post-card-location {
    color: var(--color-accent);
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-card-tag {
    background: var(--color-accent-light);
    color: var(--color-accent);
    padding: 0.2em 0.6em;
    border-radius: 12px;
    font-size: 0.8rem;
  }

  .site-footer {
    text-align: center;
    padding: 3rem 1.5rem;
    color: var(--color-text-light);
    font-size: 0.9rem;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2rem;
    }

    .nav {
      flex-direction: column;
      gap: 1rem;
    }

    .nav-links a {
      margin: 0 1rem;
    }

    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
