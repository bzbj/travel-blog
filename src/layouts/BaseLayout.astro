---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '我的旅行博客' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=Noto+Sans+SC:wght@400;500;600&display=swap" rel="stylesheet">
  <style is:global>
    :root {
      --color-bg: #fafafa;
      --color-text: #2d3748;
      --color-text-light: #718096;
      --color-accent: #ed8936;
      --color-accent-light: #fbd38d;
      --color-border: #e2e8f0;
      --font-serif: 'Noto Serif SC', Georgia, serif;
      --font-sans: 'Noto Sans SC', system-ui, sans-serif;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: var(--font-sans);
      background-color: var(--color-bg);
      color: var(--color-text);
      line-height: 1.8;
      font-size: 16px;
    }

    a {
      color: var(--color-accent);
      text-decoration: none;
      transition: color 0.2s;
    }

    a:hover {
      color: #dd6b20;
      text-decoration: underline;
    }

    img {
      max-width: 100%;
      height: auto;
      border-radius: 8px;
    }

    h1, h2, h3, h4 {
      font-family: var(--font-serif);
      font-weight: 600;
      line-height: 1.3;
      margin: 1.5em 0 0.8em;
    }

    h1 { font-size: 2.25rem; }
    h2 { font-size: 1.75rem; color: var(--color-accent); }
    h3 { font-size: 1.375rem; }
    h4 { font-size: 1.125rem; }

    p {
      margin-bottom: 1.2em;
    }

    ul, ol {
      margin: 1em 0;
      padding-left: 1.5em;
    }

    li {
      margin: 0.5em 0;
    }

    blockquote {
      border-left: 4px solid var(--color-accent);
      padding-left: 1em;
      margin: 1.5em 0;
      color: var(--color-text-light);
      font-style: italic;
    }

    code {
      background: #edf2f7;
      padding: 0.2em 0.4em;
      border-radius: 3px;
      font-family: 'Fira Code', monospace;
      font-size: 0.9em;
    }

    pre {
      background: #2d3748;
      color: #e2e8f0;
      padding: 1em;
      border-radius: 8px;
      overflow-x: auto;
      margin: 1.5em 0;
    }

    pre code {
      background: none;
      padding: 0;
    }

    hr {
      border: none;
      border-top: 2px solid var(--color-border);
      margin: 2em 0;
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
